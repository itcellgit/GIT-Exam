# Copy this file to .env and fill in real values for production.
# .env is gitignored.

# ── Server ──
PORT=4000

# Secret used to sign admin login tokens. Set a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Base URL of the FRONTEND, used to build password-reset links in emails.
# Dev: http://localhost:5173   Prod: https://your-domain.example
APP_BASE_URL=http://localhost:5173

# ── Default admin (used only on first run when server/data/users.json is absent) ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Required for "forgot password" to be able to email a reset link:
ADMIN_EMAIL=

# ── SMTP (for sending password-reset emails) ──
# If these are left blank, the reset link is printed to the server console
# instead of being emailed (handy for local testing).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
